# Gemini API Key for voice processing
# Get your API key from https://aistudio.google.com/app/apikey
GENAI_API_KEY=your_gemini_api_key_here

# Backend API URL
# For production, use your server URL (e.g., https://api.yourdomain.com)
# For local development, keep as localhost:8000
BACKEND_URL=http://localhost:8000
